<h1>Loja</h1>

<button onclick="window.location.href='/carrinho'">
    Meu Carrinho
</button>

<hr>

<% if @produtos.empty? %>

    <p>Não existem produtos disponíveis.</p>

<% else %>

    <% @produtos.each do |produto| %>

        <div class="produto">

            <h2><%= produto.nome %></h2>

            <p>
                <strong>Vendedor:</strong>
                <%= produto.vendedor.nome %>
            </p>

            <p>
                <strong>Descrição:</strong><br>
                <%= produto.descricao %>
            </p>

            <p>
                <strong>Preço:</strong>
                R$ <%= ("%.2f" % produto.preco).tr(".", ",") %>
            </p>

            <a href="/produto/<%= produto.id %>">
            <button>
            Ver Detalhes
            </button>
            </a>

        </div>

    <% end %>

<% end %>

<br>

<button onclick="window.location.href='/painel'">
    Voltar
</button>