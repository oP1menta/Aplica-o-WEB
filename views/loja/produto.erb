<h1><%= @produto.nome %></h1>

    <% if @erro %>

        <p style="color:red;">

            <%= @erro %>

        </p>

    <% end %>

    <hr>

    <p>
        <strong>Vendedor:</strong>
        <%= @produto.vendedor.nome %>
    </p>

    <p>
        <strong>Descrição:</strong><br>
        <%= @produto.descricao %>
    </p>

    <p>
        <strong>Preço:</strong>
        R$ <%= ("%.2f" % @produto.preco).tr(".", ",") %>
    </p>

    <p>
        <strong>Estoque Total:</strong>
        <%= @produto.estoque %>
    </p>

    <p>
        <strong>Disponível para compra:</strong>
        <%= @estoque_disponivel %>
    </p>

    <hr>

    <% if @estoque_disponivel > 0 %>

        <form action="/carrinho" method="POST">

            <input
                type="hidden"
                name="produto_id"
                value="<%= @produto.id %>">

            <label>Quantidade:</label><br>

            <input
                type="number"
                name="quantidade"
                min="1"
                max="<%= @estoque_disponivel %>"
                value="1"
                required>

            <br><br>

            <button type="submit">
                Adicionar ao Carrinho
            </button>

        </form>

    <% else %>

        <p style="color:red;">

            Sem estoque disponível.

        </p>

    <% end %>

    <br>

    <button onclick="window.location.href='/carrinho'">
    Ver Carrinho
    </button>

<br><br>

    <button onclick="window.location.href='/loja'">
     Voltar
    </button>