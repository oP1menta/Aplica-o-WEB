<h1>Login</h1>


    <% if @erro %>
        <p style="color: red;">
            <%= @erro %>
        </p>
    <% end %>

<form action="/login" method="POST">

    <label>Email:</label><br>
    <input type="email" name="email" required><br><br>

    <label>Senha:</label><br>
    <input type="password" name="senha" required><br><br>

    <button type="submit">
        Entrar
    </button>

</form>

<br>

<a href="/cadastro">
    Criar uma conta
</a>