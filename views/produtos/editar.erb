<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Editar Produto</title>
</head>
<body>

<h1>Editar Produto</h1>

<form action="/produtos/<%= @produto.id %>" method="POST">

    <label>Nome:</label><br>
    <input type="text"
           name="nome"
           value="<%= @produto.nome %>"
           required><br><br>

    <label>Descrição:</label><br>
    <textarea name="descricao"><%= @produto.descricao %></textarea><br><br>

    <label>Preço:</label><br>
    <input type="number"
           step="0.01"
           min="0.01"
           name="preco"
           value="<%= @produto.preco %>"
           required><br><br>

    <label>Estoque:</label><br>
    <input type="number"
           min="0"
           name="estoque"
           value="<%= @produto.estoque %>"
           required><br><br>

    <button type="submit">
        Salvar Alterações
    </button>

</form>

<br>

<a href="/produtos">
    Voltar
</a>

</body>
</html>